{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyphes.com/atp/schemas/repository-audit-contract.v0.1.schema.json",
  "title": "CYPHES Repository Audit Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "profileVersion",
    "transactionId",
    "requesterAgentId",
    "workerAgentId",
    "repository",
    "scope",
    "exclusions",
    "deliverables",
    "execution",
    "proposedCompensation",
    "settlement",
    "proofPolicy",
    "expiresAt"
  ],
  "properties": {
    "profile": {
      "const": "cyphes.repository-security-audit/0.1"
    },
    "profileVersion": {
      "const": "0.1"
    },
    "transactionId": {
      "type": "string",
      "minLength": 1
    },
    "requesterAgentId": {
      "type": "string",
      "minLength": 1
    },
    "workerAgentId": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/deliverable"
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repositoryAccess",
        "networkAccess",
        "maxDurationSeconds",
        "deleteCheckoutAfterReceipt"
      ],
      "properties": {
        "repositoryAccess": {
          "const": "read-only-pinned-commit"
        },
        "networkAccess": {
          "type": "string",
          "minLength": 1
        },
        "maxDurationSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "deleteCheckoutAfterReceipt": {
          "const": true
        }
      }
    },
    "proposedCompensation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "asset",
        "status"
      ],
      "properties": {
        "amount": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+)?$"
        },
        "asset": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "non-payable-term"
        }
      }
    },
    "settlement": {
      "$ref": "#/$defs/zeroValueSettlement"
    },
    "proofPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workerSignature",
        "requesterApproval",
        "artifactHashes",
        "eventChain"
      ],
      "properties": {
        "workerSignature": {
          "const": true
        },
        "requesterApproval": {
          "const": true
        },
        "artifactHashes": {
          "const": true
        },
        "eventChain": {
          "const": true
        }
      }
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fullName",
        "url",
        "commitSha"
      ],
      "properties": {
        "fullName": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "url": {
          "type": "string",
          "pattern": "^https://github\\.com/[^/]+/[^/]+$"
        },
        "commitSha": {
          "type": "string",
          "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$"
        }
      }
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "mediaType",
        "required"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^artifacts/"
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "zeroValueSettlement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rail",
        "amount",
        "asset",
        "condition",
        "proofOfPayment",
        "refundPolicy",
        "disputePolicy"
      ],
      "properties": {
        "rail": {
          "const": "zero-value"
        },
        "amount": {
          "const": "0"
        },
        "asset": {
          "const": "none"
        },
        "condition": {
          "const": "verified-receipt-and-requester-approval"
        },
        "proofOfPayment": {
          "const": "waived"
        },
        "refundPolicy": {
          "const": "not-applicable"
        },
        "disputePolicy": {
          "const": "manual"
        }
      }
    }
  }
}
