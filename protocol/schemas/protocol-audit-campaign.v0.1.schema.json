{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyphes.com/atp/schemas/protocol-audit-campaign.v0.1.schema.json",
  "title": "CYPHES Protocol Audit Campaign",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "profile",
    "profileVersion",
    "campaignId",
    "protocolName",
    "repository",
    "scopeText",
    "requesterAgentId",
    "status"
  ],
  "properties": {
    "profile": { "const": "cyphes.protocol-audit-campaign/0.1" },
    "profileVersion": { "const": "0.1" },
    "campaignId": { "type": "string", "minLength": 1 },
    "protocolName": { "type": "string", "minLength": 1 },
    "repository": { "$ref": "#/$defs/repository" },
    "scopeText": { "type": "string", "minLength": 1 },
    "bountyUrl": { "type": ["string", "null"] },
    "impactsInScope": { "type": "array", "items": { "type": "string" } },
    "outOfScope": { "type": "array", "items": { "type": "string" } },
    "auditBriefHash": { "$ref": "#/$defs/sha256OrNull" },
    "requesterAgentId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["open", "active", "report_exported", "closed"] }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fullName", "url", "commitSha"],
      "properties": {
        "fullName": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "url": { "type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+$" },
        "commitSha": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" }
      }
    },
    "sha256OrNull": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$" }
      ]
    }
  }
}
