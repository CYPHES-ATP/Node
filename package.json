{
  "name": "cyphes-desktop",
  "private": true,
  "version": "0.16.10",
  "description": "Native ATP node for verifiable repository audit work orders",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CYPHES-ATP/Node.git"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run build && node scripts/assert-genesis-auto-mode.mjs && cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo check --manifest-path src-tauri/Cargo.toml && cargo test --manifest-path src-tauri/Cargo.toml && cargo fmt --manifest-path source-gateway/Cargo.toml --check && cargo test --manifest-path source-gateway/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:worker": "tauri build --config src-tauri/tauri.worker.conf.json",
    "tauri:build:partner": "tauri build --config src-tauri/tauri.partner.conf.json",
    "release:mac:v0.16.7": "npm run tauri:build:worker"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^20.19.43",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^8.0.16"
  }
}
